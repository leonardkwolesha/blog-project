PORT=2030

# MongoDB — get connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — any long random string (keep this secret)
JWT_SECRET=some_long_random_secret_here

# Cloudinary — get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP — use a Gmail App Password, NOT your regular Gmail password
# How to get one: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend origin (comma-separated for multiple environments)
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app
